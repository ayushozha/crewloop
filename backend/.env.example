# Backend reads from ../.env and ../.env.local (project root) by default.
# This file documents which AGENTPHONE_* keys are required.
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-3-flash-preview
GEMINI_MODEL_PRO=gemini-3.1-pro-preview

AGENTPHONE_API_KEY=
AGENTPHONE_BASE_URL=https://api.agentphone.ai/v1

# Populated by backend/scripts/provision_agentphone.py
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_FROM_NUMBER=
AGENTPHONE_WEBHOOK_SECRET=

AGENTPHONE_WEBHOOK_URL=https://crewloop-api.ayushojha.com/webhooks/agentphone

BROWSER_USE_API_KEY=
BROWSER_USE_BASE_URL=https://api.browser-use.com/api/v3
BROWSER_USE_MODEL=bu-mini

SUPERMEMORY_API_KEY=
SUPERMEMORY_CONTAINER_TAG=crewloop:owner:ayush

# Postgres connection (shared projects-postgres, db `crewloop`).
DATABASE_URL=postgres://admin:PASSWORD@projects-postgres:5433/crewloop?sslmode=disable
